<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow dynamic loading of libraries without signature validation. Used for 3dconnection drivers. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- WebKit running board assertions -->
    <key>com.apple.runningboard.assertions.webkit</key>
    <true/>
    <!-- Network client access (required for HTTP requests) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Network server access (required for local HTTP server) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- User-selected file access -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Downloads folder access -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- Allow JIT compilation (required for JavaScript engines) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow unsigned executable memory (required for JIT) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow DYLD environment variables -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
