#!/usr/bin/env bash

export ROOT=$(echo $ROOT | grep . || pwd)
export NCORES=`nproc --all`

while getopts ":ih" opt; do
  case ${opt} in
    i )
        export BUILD_IMAGE="1"
        ;;
    h ) echo "Usage: ./build_linux_image.sh [-i]"
        echo "   -i: Generate Appimage (optional)"
        exit 0
        ;;
  esac
done

echo -n "[9/9] Generating Linux app..."
#{
    # create directory and copy into it
    if [ -d "package" ]
    then
        rm -rf package/*
        rm -rf package/.* 2&>/dev/null
    else
        mkdir package
    fi
    mkdir package/bin

    # copy Resources
    cp -Rf ../resources package/resources
    
    # Find and copy the @SLIC3R_APP_CMD@ binary from Multi-Config build
    if [ -f "src/Release/@SLIC3R_APP_CMD@" ]; then
        cp -f src/Release/@SLIC3R_APP_CMD@ package/bin/@SLIC3R_APP_CMD@
    elif [ -f "src/@SLIC3R_APP_CMD@" ]; then
        # Fallback for single-config builds
        cp -f src/@SLIC3R_APP_CMD@ package/bin/@SLIC3R_APP_CMD@
    else
        echo "Error: @SLIC3R_APP_CMD@ binary not found in any configuration directory"
        exit 1
    fi
    # remove unneeded po from resources
    ## find package/resources/localization -name "*.po" -type f -delete ## FIXME: DD - do we need this?

    # create bin
cat << EOF >@SLIC3R_APP_CMD@
#!/bin/bash
DIR=\$(readlink -f "\$0" | xargs dirname)
export LD_LIBRARY_PATH="\$DIR/bin:\$LD_LIBRARY_PATH"

# FIXME: OrcaSlicer segfault workarounds
# 1) OrcaSlicer will segfault on systems where locale info is not as expected (i.e. Holo-ISO arch-based distro)
export LC_ALL=C

# Optionally route OpenGL through the Mesa/zink driver. This is OPT-IN:
# export ZINK_FORCE_OVERRIDE=1 to enable it. It used to be forced automatically
# on NVIDIA + Wayland (driver > 555) to work around a blank 3D viewport, but
# that was caused by the GLEW OpenGL loader failing to initialise; since the
# migration to GLAD the native GL driver renders the viewport correctly.
# Forcing zink is in fact harmful on some NVIDIA setups (it can fail to create
# a Vulkan swapchain: "zink: could not create swapchain"), so it is no longer
# enabled by default.
if [ "\$ZINK_FORCE_OVERRIDE" = "1" ]; then
    export __GLX_VENDOR_LIBRARY_NAME=mesa
    export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/50_mesa.json
    export MESA_LOADER_DRIVER_OVERRIDE=zink
    export GALLIUM_DRIVER=zink
    export WEBKIT_DISABLE_DMABUF_RENDERER=1
fi
exec "\$DIR/bin/@SLIC3R_APP_CMD@" "\$@"
EOF

    chmod ug+x @SLIC3R_APP_CMD@
    cp -f @SLIC3R_APP_CMD@ package/@SLIC3R_APP_CMD@
    pushd package > /dev/null
    tar -cvf ../@SLIC3R_APP_KEY@.tar .  &>/dev/null
    popd > /dev/null
#} &> $ROOT/Build.log # Capture all command output
echo "done"

if [[ -n "$BUILD_IMAGE" ]]
then
echo -n "Creating Appimage for distribution..."
#{
    pushd package > /dev/null
    chmod +x ../build_appimage.sh
    ../build_appimage.sh
    popd > /dev/null
    mv package/"@SLIC3R_APP_KEY@_Linux_V@Snapmaker_VERSION@.AppImage" "@SLIC3R_APP_KEY@_Linux_V@Snapmaker_VERSION@.AppImage"
#} &> $ROOT/Build.log # Capture all command output
echo "done"
fi
